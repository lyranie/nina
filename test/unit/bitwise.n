mod test.bitwise;

void test() {
    int test  = 0xAA & 0x55;
    int test1 = 0xAA | 0x55;
    int test2 = 0xAA ^ 0x55;
    int test3 = ~0xAA;
    int test4 = 0xF << 0x2;
    int test5 = 0xFF >> 0x2;
}

