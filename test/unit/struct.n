mod test.struct;

type Person(char* name, int age);

void test () {
    Person test = new Person("Allie", 23);

    char* name = "Christoffer";
    int   age  = 53;

    Person test1 = new Person(name, age);
}

/*
%test.struct.Person = type { ptr, i32 }

@0 = private unnamed_addr constant [6 x i8] c"Allie\00"
@1 = private unnamed_addr constant { ptr, i32 } { ptr @0, i32 5 }
@2 = private unnamed_addr constant [12 x i8] c"Christoffer\00"
@3 = private unnamed_addr constant { ptr, i32 } { ptr @2, i32 11 }

define void @test.struct.test() {
entry:
  %test = alloca %test.struct.Person, align 8
  store %test.struct.Person { ptr @0, i32 23 }, ptr %test, align 8
  %name = alloca ptr, align 8
  store ptr @2, ptr %name, align 8
  %age = alloca i32, align 4
  store i32 53, ptr %age, align 4
  %test1 = alloca %test.struct.Person, align 8
  %0 = load ptr, ptr %name, align 8
  %1 = load i32, ptr %age, align 4
  %2 = alloca %test.struct.Person, align 8
  %3 = getelementptr inbounds nuw %test.struct.Person, ptr %2, i32 0, i32 0
  store ptr %0, ptr %3, align 8
  %4 = getelementptr inbounds nuw %test.struct.Person, ptr %2, i32 0, i32 1
  store i32 %1, ptr %4, align 4
  %5 = load %test.struct.Person, ptr %2, align 8
  store %test.struct.Person %5, ptr %test1, align 8
  ret void
  unreachable
}
