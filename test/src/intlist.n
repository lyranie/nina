mod intarray;

use libc;
use std.io;
use std.core.allocator.arena;

type IntArray(Arena* arena, int* entries, int num_entries, int size);

IntArray create(Arena* arena, int default_size) {
    int* entries = arena.alloc(arena, 4 * default_size, 4);
    libc.memset(entries, 0, 4 * default_size);

    ret new IntArray(arena, entries, 0, default_size);
}

void add(IntArray* list, int i) {
    if (list.num_entries + 1 >= list.size) {
        int  new_size    = list.size * 2;
        int* new_entries = arena.alloc(list.arena, 4 * new_size, 4);

        libc.memcpy(new_entries, list.entries, 4 * list.num_entries);
        list.entries = new_entries;
        list.size = new_size;
    }

    int* dst = list.entries + list.num_entries;

    libc.memcpy(dst, &i, 4);
    list.num_entries++;
}

int get(IntArray* list, int i) {
    if (i >= list.num_entries) {
        ret 0;
    }

    ret *(list.entries + i);
}

bool remove(IntArray* list, int i) {
    if (i >= list.num_entries) {
        ret false;
    }

    int* dst   = list.entries + i;
    int* src   = list.entries + i + 1;
    int  count = list.num_entries - i - 1;

    libc.memcpy(dst, src, 4 * count);

    int* last = list.entries + list.num_entries - 1;
    libc.memset(last, 0, 4);

    list.num_entries--;

    ret true;
}
