mod test.main;

ext void InitWindow( int width, int height,char* name);
ext void BeginDrawing();
ext void EndDrawing();
ext void ClearBackground(Color);
ext bool WindowShouldClose();

type Color(char r, char g, char b, char a);

int main(){

    int width = 9;
    InitWindow(800,600,"foo");

    Color col = new Color(255, 0, 0, 255);
    while (!WindowShouldClose()){
        BeginDrawing();
        ClearBackground(col);
        EndDrawing();
    }
    
    ret 69;
}
