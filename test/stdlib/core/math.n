mod test.std.core.math;

use test;
use std.core.math;

void test() {
    test.assert(math.add(3, 4) == 7,    "add(3, 4) should be 7");
    test.assert(math.sub(10, 4) == 6,   "sub(10, 4) should be 6");
    test.assert(math.mul(6, 7) == 42,   "mul(6, 7) should be 42");
    test.assert(math.div(20, 4) == 5,   "div(20, 4) should be 5");
    test.assert(math.sqr(5) == 25,      "sqr(5) should be 25");
    test.assert(math.cube(3) == 27,     "cube(3) should be 27");
    test.assert(math.avg(10, 20) == 15, "avg(10, 20) should be 15");

    test.assert(math.max(420, 69) == 420, "max(420, 69) should be 420");
    test.assert(math.min(420, 69) == 69,  "min(420, 69) should be 69");

    test.assert(math.abs(69) == 69,  "abs(69) should be 69");
    test.assert(math.abs(-69) == 69, "abs(-69) should be 69");
    
    test.assert(math.sign(5) == 1,   "sign(5) should be 1");
    test.assert(math.sign(-1) == -1, "sign(-5) should be -1");
    test.assert(math.sign(0) == 0,   "sign(0) should be 0");

    test.assert(math.pow(2, 10) == 1024, "pow(2, 10) should be 1024");
    test.assert(math.pow(5, 0) == 1,     "pow(5, 0) should be 1");

    test.assert(math.factorial(5) == 120, "factorial(5) should be 120");
    test.assert(math.factorial(1) == 1,   "factorial(1) should be 1");

    test.assert(math.gcd(48, 18) == 6, "gcd(48, 18) should be 6");
    test.assert(math.gcd(17, 5) == 1,  "gcd(17, 5) should be 1");

    test.assert(math.fib(0) == 0,   "fib(0) should be 0");
    test.assert(math.fib(1) == 1,   "fib(1) should be 1");
    test.assert(math.fib(10) == 55, "fib(10) should be 55");

    test.assert(math.sum_to_n(0) == 0,   "sum_to_n(0) should be 0");
    test.assert(math.sum_to_n(10) == 55, "sum_to_n(10) should be 55");

    test.assert(math.is_even(0), "is_even(0) should be true");
    test.assert(math.is_even(4), "is_even(4) should be true");
    test.assert(math.is_odd(1),  "is_odd(1) should be true");
    test.assert(math.is_odd(7),  "is_odd(7) should be true");

    test.assert(math.is_prime(2),  "is_prime(2) should be true");
    test.assert(math.is_prime(17), "is_prime(17) should be true");
}
