mod libc;

ext int   printf(char* fmt, args...);
ext void* malloc(int size);
ext void* memcpy(void* dst, void* src, int len);
ext void* memset(void* dst, int value, int len);
ext void* realloc(void* ptr, int size);
ext int   open(char* path, int flags, int mode);
ext int   close(int fd);
ext int   read(int fd, void* buf, int count);
ext int   write(int fd, void* buf, int count);
ext int   lseek(int fd, int offset, int whence);
ext int*  __errno_location();
