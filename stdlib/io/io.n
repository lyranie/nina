mod std.io;

use std.core.string;
use libc;

void printn(any a) {
    if (a.$typeid == str.$typeid) {
        libc.printf("%s", a.$data.ptr);
    } else if (a.$typeid == int.$typeid) {
        libc.printf("%d", a.$data);
    } else if (a.$typeid == bool.$typeid) {
        if (a.$data) {
            libc.printf("true");
        } else {
            libc.printf("false");
        }
    } else {
        libc.printf("<UNKNOWN>");
    }

    libc.printf("\n");
}
